# Fire Whisper RPG Environment Configuration
# Copy this file to .env.local for local development

# ===========================================
# AI API CONFIGURATION
# ===========================================
CLAUDE_API_KEY=your_claude_api_key_here

# ===========================================
# DEPLOYMENT MODE
# ===========================================
# Set to 'local' for development, 'aws' for production
DEPLOYMENT_MODE=local

# ===========================================
# LOCAL DEVELOPMENT SETTINGS
# ===========================================
LOCAL_PORT=3000
DEBUG_MODE=true
LOG_LEVEL=DEBUG

# ===========================================
# AWS PRODUCTION SETTINGS (only needed for AWS mode)
# ===========================================
AWS_REGION=us-east-1
AWS_LAMBDA_FUNCTION_NAME=fire-whisper-game
AWS_S3_BUCKET=fire-whisper-assets
AWS_DYNAMODB_TABLE=fire-whisper-game-data

# ===========================================
# GAME CONFIGURATION
# ===========================================
MAX_TURNS_PER_GAME=100
DEFAULT_CHARACTER_LEVEL=1
ENABLE_ANALYTICS=false